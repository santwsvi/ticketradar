# Variáveis de ambiente — copie para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env

PORT=8080
DB_PATH=./ticketradar.db
CHECK_INTERVAL=30s

# CORS — domínio do frontend em produção (ex: https://ticketradar.app)
ALLOWED_ORIGIN=http://localhost:8080

# Token para endpoints protegidos (DELETE /api/waitlist, GET /api/me)
# Gere um token forte: openssl rand -hex 32
DELETE_TOKEN=CHANGE_ME

# Email (Gmail App Password)
# Gere em: myaccount.google.com/apppasswords
EMAIL_FROM=seu@gmail.com
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_TO=seu@gmail.com

# Twilio SMS
# Crie conta em: twilio.com
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM=+1XXXXXXXXXX
TWILIO_TO=+55XXXXXXXXXXX
