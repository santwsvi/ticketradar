# Variáveis de ambiente — copie para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env

# Servidor
PORT=8080
DB_PATH=./ticketradar.db
CHECK_INTERVAL=30s

# CORS — domínio do frontend em produção
ALLOWED_ORIGIN=http://localhost:8080

# Admin — acesso às rotas internas (/dashboard, /docs, /admin/db, /metrics)
# Gere uma senha forte: openssl rand -hex 16
ADMIN_USER=admin
ADMIN_PASS=CHANGE_ME

# Token para endpoints LGPD (DELETE /api/waitlist, GET /api/me)
# Gere: openssl rand -hex 32
DELETE_TOKEN=CHANGE_ME

# Email — Resend API (https://resend.com)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@ticketradar.com.br
EMAIL_TO=seu@email.com

# Twilio SMS (https://twilio.com)
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM=+1XXXXXXXXXX
TWILIO_TO=+55XXXXXXXXXXX

# Fase 0.2: Better Stack Logs (https://betterstack.com/logs)
# Crie uma Source → HTTP → copie o token
BETTERSTACK_TOKEN=

# Fase 1: Grafana Cloud (https://grafana.com/products/cloud/)
# Opcional — /metrics expõe Prometheus sem esse token
# Configure o scraper no Grafana Cloud apontando para /metrics com Basic Auth
